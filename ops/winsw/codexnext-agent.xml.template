<service>
  <id>codexnext-agent</id>
  <name>CodexNext Relay Agent</name>
  <description>Runs the outbound CodexNext relay agent on a Windows host.</description>
  <executable>%SystemRoot%\System32\WindowsPowerShell\v1.0\powershell.exe</executable>
  <arguments>-NoProfile -ExecutionPolicy Bypass -Command "&amp; { $ErrorActionPreference = 'Stop'; Set-Location -LiteralPath $env:CODEXNEXT_ROOT; $cmdArgs = @('connect', '--relay', $env:CODEXNEXT_RELAY_URL, '--approval-timeout-ms', $env:CODEXNEXT_APPROVAL_TIMEOUT_MS, '--codex-bin', $env:CODEXNEXT_CODEX_BIN); if ($env:CODEXNEXT_DEVICE_NAME) { $cmdArgs += @('--device-name', $env:CODEXNEXT_DEVICE_NAME) }; pnpm --filter @codexnext/agent dev -- @cmdArgs }"</arguments>
  <workingdirectory>%CODEXNEXT_ROOT%</workingdirectory>
  <env name="CODEXNEXT_ROOT" value="C:\codexnext" />
  <env name="CODEXNEXT_RELAY_URL" value="https://relay.example.invalid" />
  <env name="CODEXNEXT_DEVICE_NAME" value="Windows" />
  <env name="CODEXNEXT_CODEX_BIN" value="codex" />
  <env name="CODEXNEXT_APPROVAL_TIMEOUT_MS" value="300000" />
  <onfailure action="restart" delay="5 sec" />
  <stoptimeout>20 sec</stoptimeout>
  <stopparentprocessfirst>true</stopparentprocessfirst>
  <logpath>%BASE%\logs</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10485760</sizeThreshold>
    <keepFiles>8</keepFiles>
  </log>
</service>

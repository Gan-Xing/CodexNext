<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.codexnext.relay-agent</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>__CODEXNEXT_ROOT__/ops/launchd/run-relay-agent.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__CODEXNEXT_ROOT__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/codexnext-relay-agent.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/codexnext-relay-agent.log</string>
  </dict>
</plist>

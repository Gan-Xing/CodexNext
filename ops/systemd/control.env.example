CODEXNEXT_OWNER_TOKEN=replace-with-long-random-token
CODEXNEXT_CONTROL_HOST=0.0.0.0
CODEXNEXT_CONTROL_PORT=3922
CODEXNEXT_PRODUCTION=1
CODEXNEXT_PUBLIC_WEB_ORIGIN=https://<your-web-origin>
CODEXNEXT_ALLOWED_ORIGINS=https://<your-web-origin>
CODEXNEXT_ALLOW_MACHINE_OWNER_TOKEN=0
CODEXNEXT_DISABLE_RELAY_FULL_ACCESS=0
CODEXNEXT_HEARTBEAT_INTERVAL_MS=15000
# Optional. Defaults to 4x CODEXNEXT_HEARTBEAT_INTERVAL_MS when unset.
CODEXNEXT_STALE_DEVICE_TIMEOUT_MS=
CODEXNEXT_RPC_TIMEOUT_MS=30000

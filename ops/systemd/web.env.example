CODEXNEXT_RELAY_URL=https://<your-relay-host>
CODEXNEXT_OWNER_TOKEN=replace-with-long-random-token
CODEXNEXT_PUBLIC_ORIGIN=https://<your-web-origin>
CODEXNEXT_WEB_HOST=0.0.0.0
CODEXNEXT_WEB_PORT=3002
CODEXNEXT_WEB_AUTH_PASSWORD_HASH=replace-with-scrypt-hash
CODEXNEXT_WEB_SESSION_SECRET=replace-with-long-random-secret
CODEXNEXT_DISABLE_RELAY_FULL_ACCESS=0

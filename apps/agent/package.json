{
  "name": "@codexnext/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "codexnext": "./src/index.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codexnext/codex-client": "workspace:*",
    "@codexnext/protocol": "workspace:*",
    "codex-provider": "0.1.0-alpha.0",
    "commander": "^14.0.2",
    "pino": "^10.1.0",
    "socket.io-client": "^4.8.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
